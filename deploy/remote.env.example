# 复制为 deploy/remote.env 后按需修改（deploy/remote.env 勿提交仓库）
#
# 本地部署脚本会 source 本文件以读取 DEPLOY_*，并 rsync 到服务器供 docker compose 插值。

# SSH Host（~/.ssh/config 里的 Host，例如 dz）
DEPLOY_SSH=dz

# 远端项目目录：请填服务器上的绝对路径（勿写 ~/，在本机 source 时 ~ 会错误展开到 Mac 家目录）
DEPLOY_REMOTE_DIR=/root/faleme

# 浏览器访问站点时的「公开来源」origin（用于 CORS / 跳转文案，勿尾斜杠）
# 例：https://fa.example.com  若暂时用 IP+端口：http://203.0.113.10:3003
FALEME_PUBLIC_ORIGIN=https://你的域名或http://服务器IP:3003

# 与 FALEME_PUBLIC_ORIGIN 填成一样即可（除非营销站单独域名）
FALEME_MARKETING_URL=https://你的域名或http://服务器IP:3003

# 前端请求 API 的基址。与 Nginx 同域反代 /api 时留空（推荐）
VITE_API_BASE_URL=

# App Store / 支持联系邮箱
FALEME_SUPPORT_EMAIL=support@example.com

# ---- 可选：scripts/deploy-remote.sh 打 Git 部署标签（默认开启）----
# DEPLOY_SKIP_TAG=1              跳过打 tag / 推送 tag
# DEPLOY_TAG=v1.2.3-prod         自定义标签名（须本地尚不存在）
# DEPLOY_ALLOW_DIRTY=1           有未提交修改仍部署（默认会拒绝）
# DEPLOY_PUSH_BRANCH=1           部署前先把当前分支 push 到 origin
